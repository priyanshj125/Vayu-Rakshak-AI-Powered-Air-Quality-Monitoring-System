# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Required for AI Chatbot ───────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── Database ──────────────────────────────────────────────
# By default we use sqlite, but you can set this to use Microsoft SQL Server (Azure SQL)
# Example for Azure SQL: 
# DATABASE_URL=mssql+pyodbc://<username>:<password>@<server_name>.database.windows.net:1433/<db_name>?driver=ODBC+Driver+18+for+SQL+Server
DATABASE_URL=sqlite:///./air_quality.db

# ── Optional: Override the FastAPI base URL ───────────────
# VAYU_API_BASE=http://localhost:8000

# ── Azure Storage ─────────────────────────────────────────
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account;...
